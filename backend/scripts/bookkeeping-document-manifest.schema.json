{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datatalks.club/schemas/bookkeeping-document-manifest-v1.json",
  "title": "Bookkeeping document import manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "archives", "documents", "exclusions"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "archives": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alias", "year", "sha256"],
        "properties": {
          "alias": { "$ref": "#/$defs/opaque" },
          "year": { "type": "integer", "minimum": 2000, "maximum": 2100 },
          "sha256": { "$ref": "#/$defs/hash" }
        }
      }
    },
    "documents": {
      "type": "array",
      "maxItems": 5000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sha256", "sources", "documentType", "transactions"],
        "properties": {
          "sha256": { "$ref": "#/$defs/hash" },
          "sources": {
            "type": "array",
            "minItems": 1,
            "maxItems": 64,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["archive", "member"],
              "properties": {
                "archive": { "$ref": "#/$defs/opaque" },
                "member": { "type": "string", "minLength": 1, "maxLength": 1024 }
              }
            }
          },
          "documentType": { "enum": ["invoice", "receipt", "bank-statement", "private-account-statement", "other-evidence"] },
          "accountId": { "$ref": "#/$defs/opaque" },
          "statementMonth": { "type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$" },
          "transactions": {
            "type": "array",
            "maxItems": 1000,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["coverageType"],
              "properties": {
                "sourceKey": { "$ref": "#/$defs/opaque" },
                "transactionId": { "$ref": "#/$defs/opaque" },
                "coverageType": { "enum": ["evidence", "statement-coverage"] }
              },
              "oneOf": [
                { "required": ["sourceKey"], "not": { "required": ["transactionId"] } },
                { "required": ["transactionId"], "not": { "required": ["sourceKey"] } }
              ]
            }
          },
          "unlinkedApproved": { "type": "boolean" }
        }
      }
    },
    "exclusions": {
      "type": "array",
      "maxItems": 5000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["archive", "member", "reason"],
        "properties": {
          "archive": { "$ref": "#/$defs/opaque" },
          "member": { "type": "string", "minLength": 1, "maxLength": 1024 },
          "reason": { "enum": ["unsupported-image", "nested-packaging-archive"] }
        }
      }
    }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^(sha256:)?[a-f0-9]{64}$" },
    "opaque": { "type": "string", "pattern": "^[A-Za-z0-9._:-]{1,300}$" }
  }
}
